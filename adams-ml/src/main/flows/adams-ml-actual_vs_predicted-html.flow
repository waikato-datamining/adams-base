# Project: adams
# Date: 2026-05-05 13:24:08
# User: fracpete
# Charset: UTF-8
# Modules: adams-core,adams-math,adams-ml,adams-spreadsheet,adams-visualstats
#
adams.flow.control.Flow -annotation "Generates HTML code for displaying actual vs predicted values." -execute-on-error adams.flow.control.postflowexecution.Null -execute-on-finish adams.flow.control.postflowexecution.Null -flow-execution-listener adams.flow.execution.NullListener -flow-restart-manager adams.flow.control.flowrestart.NullManager
 adams.flow.standalone.GridView -width 1200 -num-cols 3 -writer adams.gui.print.NullWriter
  adams.flow.sink.SpreadSheetDisplay -name Predictions -writer adams.data.io.output.NullWriter
  adams.flow.sink.ActualVsPredictedPlot -display-type adams.flow.core.displaytype.Default -writer adams.gui.print.NullWriter -title fat -show-side-panel false -meta-data-color adams.gui.visualization.sequence.metadatacolor.Dummy
 adams.flow.standalone.CallableActors
  adams.flow.sink.HistoryDisplay -display-type adams.flow.core.displaytype.Default -entry-name-variable type
 adams.flow.source.FileSupplier -file ${FLOWS}/data/bodyfat_predictions.csv
 adams.flow.transformer.SpreadSheetFileReader -reader "adams.data.io.input.CsvSpreadSheetReader -data-row-type adams.data.spreadsheet.DenseDataRow -spreadsheet-type adams.data.spreadsheet.DefaultSpreadSheet"
 adams.flow.control.Tee -name "scatter plot"
  adams.flow.transformer.SetVariable -var-name type -var-value "scatter plot"
  adams.flow.transformer.ActualVsPredictedProcessor -processor "adams.flow.transformer.actualvspredictedprocessor.ClassifierErrors -title bodyfat"
  adams.flow.sink.CallableSink -callable HistoryDisplay
 adams.flow.control.Tee -name "KDE plot"
  adams.flow.transformer.SetVariable -var-name type -var-value "kernel density estimate plot"
  adams.flow.transformer.ActualVsPredictedProcessor -processor "adams.flow.transformer.actualvspredictedprocessor.ClassifierErrorsKernelDensityEstimate -title bodyfat"
  adams.flow.sink.CallableSink -callable HistoryDisplay